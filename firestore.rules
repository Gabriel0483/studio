
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Global administrative override for the system owners
    function isPlatformAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rielmagpantay@gmail.com' || 
        request.auth.token.email == 'mariel.dumaoal@gmail.com'
      );
    }

    // Check if the user is a registered staff member
    function isStaff() {
      return isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/staff/$(request.auth.uid)));
    }
    
    function getStaffData() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isPlatformAdmin() || (isStaff() && role in getStaffData().roles);
    }
    
    // System-wide administrative access
    match /{document=**} {
      allow read, write: if isPlatformAdmin();
    }

    // System configuration
    match /config/settings {
      allow read: if true;
      allow write: if hasRole('Super Admin') || hasRole('Operations Manager');
    }

    match /staff/{staffId} {
      allow get: if request.auth.uid == staffId || isStaff();
      allow list: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if hasRole('Super Admin');
    }

    match /passengers/{passengerId} {
      allow get: if request.auth.uid == passengerId || isStaff();
      allow list: if isStaff();
      allow create: if isSignedIn();
      allow update: if request.auth.uid == passengerId || isStaff();
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /ports/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /ships/{id} {
      allow read: if isStaff();
      allow write: if hasRole('Super Admin') || hasRole('Operations Manager');
    }

    match /routes/{id} {
      allow read: if true;
      allow write: if hasRole('Super Admin') || hasRole('Operations Manager');
    }

    match /fares/{id} {
      allow read: if true;
      allow write: if hasRole('Super Admin') || hasRole('Operations Manager');
    }

    match /schedules/{id} {
      allow read: if true;
      // Allow any signed-in user to create/update as part of booking seat decrementing
      allow create, update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /bookings/{id} {
      // Individual get: Owner or Staff
      allow get: if isSignedIn() && (resource.data.passengerId == request.auth.uid || isStaff());
      
      // List: Owner must use filter, or Staff sees all
      allow list: if isSignedIn() && (
        (request.query.limit <= 500 && resource.data.passengerId == request.auth.uid) || 
        isStaff() ||
        hasRole('Finance/Accounting')
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.passengerId == request.auth.uid || isStaff());
      allow delete: if hasRole('Super Admin');
    }

    match /maintenanceRecords/{id} {
      allow read, write: if isStaff();
    }
    
    match /boarding/{id} {
      allow read: if isStaff();
      allow write: if isStaff() || hasRole('Crew');
    }
  }
}
