
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getStaffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    
    function getStaffData() {
        return getStaffDoc().data;
    }

    function getStaffRoles() {
      return exists(/databases/$(database)/documents/staff/$(request.auth.uid))
        ? getStaffData().roles
        : [];
    }
    
    function isSuperAdmin() {
      return isSignedIn() && getStaffRoles().hasAny(['Super Admin']);
    }

    function isOperationsManager() {
      return isSignedIn() && getStaffRoles().hasAny(['Super Admin', 'Operations Manager']);
    }

    function isFinance() {
      return isSignedIn() && getStaffRoles().hasAny(['Super Admin', 'Finance/Accounting']);
    }
    
    function isStationManager() {
        return isSignedIn() && getStaffRoles().hasAny(['Super Admin', 'Operations Manager', 'Station Manager']);
    }

    function isDeskBookingAgent() {
        return isSignedIn() && getStaffRoles().hasAny(['Super Admin', 'Station Manager', 'Desk Booking Agent']);
    }
    
    function isAnyAdmin() {
        return isSignedIn() && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    
    function canStaffAccessBooking(bookingResource) {
        if (!isAnyAdmin()) {
            return false;
        }
        if (isSuperAdmin() || isOperationsManager()) {
            return true;
        }
        let staffData = getStaffData();
        if (staffData.roles.hasAny(['Station Manager', 'Desk Booking Agent'])) {
            return bookingResource.data.departurePortName == staffData.assignedPortName;
        }
        return false;
    }
    
    function canStaffAccessSchedule(scheduleResource) {
        if (!isAnyAdmin()) {
            return false;
        }
        if (isSuperAdmin() || isOperationsManager()) {
            return true;
        }
        let staffData = getStaffData();
        if (staffData.roles.has('Station Manager')) {
            return scheduleResource.data.departurePortName == staffData.assignedPortName;
        }
        return false;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    match /staff/{staffId} {
      // Simplified read rule to avoid circular dependency
      allow get: if isOwner(staffId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /passengers/{passengerId} {
      allow get: if isOwner(passengerId) || isDeskBookingAgent();
      allow list: if isDeskBookingAgent();
      allow create: if isOwner(passengerId) && request.resource.data.id == passengerId;
      allow update: if isOwner(passengerId) || isDeskBookingAgent();
      allow delete: if isOwner(passengerId) || isDeskBookingAgent();
    }
    
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isStationManager() || isOperationsManager();
    }
    
    match /ports/{portId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isOperationsManager();
    }

    match /ships/{shipId} {
      allow read: if isAnyAdmin();
      allow write: if isSuperAdmin() || isOperationsManager();
    }

    match /routes/{routeId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isOperationsManager();
    }

    match /fares/{fareId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isOperationsManager();
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow create: if canStaffAccessSchedule(request.resource);
      allow update: if canStaffAccessSchedule(request.resource);
      allow delete: if canStaffAccessSchedule(resource);
    }

    match /bookings/{bookingId} {
      allow get: if (isOwner(resource.data.passengerId) && !isAnyAdmin()) || canStaffAccessBooking(resource) || isFinance();
      allow list: if isDeskBookingAgent() || isFinance() || isOperationsManager();
      allow create: if (isOwner(request.resource.data.passengerId) && !isAnyAdmin()) || canStaffAccessBooking(request.resource);
      allow update: if (isOwner(request.resource.data.passengerId) && !isAnyAdmin()) || canStaffAccessBooking(request.resource);
      allow delete: if (isOwner(request.resource.data.passengerId) && !isAnyAdmin()) || canStaffAccessBooking(resource);
    }

    match /maintenanceRecords/{maintenanceRecordId} {
      allow read, write: if isSuperAdmin() || isOperationsManager();
    }
    
    match /boarding/{boardingId} {
        allow read, write: if isStationManager() || isOperationsManager();
    }
  }
}
