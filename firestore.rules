
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Base Authentication Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Platform Admin check (Hardcoded for bootstrap) ---
    function isPlatformAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rielmagpantay@gmail.com' || 
        request.auth.token.email == 'mariel.dumaoal@gmail.com'
      );
    }

    // --- Staff Verification (Defensive Lookups) ---
    function isStaff() {
      return isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/staff/$(request.auth.uid)));
    }
    
    function getStaffData() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isPlatformAdmin() || (isStaff() && role in getStaffData().roles);
    }
    
    // --- Global Access for Platform Admins ---
    match /{document=**} {
      allow read, write: if isPlatformAdmin();
    }

    // --- System Configuration ---
    match /config/settings {
      allow read: if true;
      allow write: if isSignedIn() && (hasRole('Super Admin') || hasRole('Operations Manager'));
    }

    // --- Staff Management ---
    match /staff/{staffId} {
      allow get: if isSignedIn() && (request.auth.uid == staffId || isStaff());
      allow list: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && hasRole('Super Admin');
    }

    // --- Passenger Profiles ---
    match /passengers/{passengerId} {
      allow get: if isOwner(passengerId) || isStaff();
      allow list: if isStaff();
      allow create: if isSignedIn();
      allow update: if isOwner(passengerId) || isStaff();
    }
    
    // --- Public Content ---
    match /announcements/{id} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /ports/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /tenants/{id} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // --- Operational Fleet & Routes ---
    match /ships/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (hasRole('Super Admin') || hasRole('Operations Manager'));
    }

    match /routes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && (hasRole('Super Admin') || hasRole('Operations Manager'));
    }

    match /fares/{id} {
      allow read: if true;
      allow write: if isSignedIn() && (hasRole('Super Admin') || hasRole('Operations Manager'));
    }

    // --- Trip Schedules ---
    match /schedules/{id} {
      allow read: if true;
      allow create, update: if isSignedIn(); 
      allow delete: if isStaff();
    }

    // --- Passenger Bookings ---
    match /bookings/{id} {
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.passengerId == request.auth.uid || 
        isStaff()
      );
      
      allow list: if isSignedIn() && (
        (resource.data.passengerId == request.auth.uid) || 
        isStaff()
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.passengerId == request.auth.uid || 
        isStaff()
      );
      
      allow delete: if hasRole('Super Admin');
    }

    // --- Internal Operations Records ---
    match /maintenanceRecords/{id} {
      allow read, write: if isStaff();
    }
    
    match /boarding/{id} {
      allow read, write: if isStaff();
    }
  }
}
