
/**
 * @title Firebase Security Rules for Isla Konek (Prototyping Mode)
 * @author Firebase Security Rules Architect
 * @version 1.9
 *
 * @description
 * This ruleset is designed for the Isla Konek application during its prototyping phase.
 * It prioritizes strict authorization (who can access what) while maintaining
 * flexibility in data schemas to allow for rapid development and iteration.
 *
 * @philosophy
 * The core security philosophy is a hybrid model:
 * 1. User-Ownership: Passengers have direct control over their own data, such as their
 *    personal information and bookings. Access is strictly limited to the data owner.
 * 2. Role-Based Access Control (RBAC): System-level data, such as ships, routes,
 *    schedules, and maintenance records, is managed by authorized personnel with an
 *    'admin' custom claim. This prevents unauthorized modification of critical data.
 * 3. Public Read: Non-sensitive, publicly relevant information like routes and schedules
 *    is readable by anyone, including unauthenticated users, to support the application's
 *    core user experience.
 *
 * @structure
 * The data structure consists of several top-level collections. There are no nested
 * user subcollections. This design choice ensures that security rules for each
 * collection are straightforward and that list operations are performant and secure.
 *
 * @decisions
 * - Default Deny: All paths are closed by default. Access is granted explicitly.
 * - No User Listing: Listing documents in the `/passengers` collection is disabled to
 *   protect user privacy and prevent data scraping, except by admins.
 * - Denormalization for Authorization: Booking documents contain a `passengerId` field.
 *   This avoids costly `get()` calls in security rules, allowing for fast ownership checks.
 * - Custom Claims for Admin: The `isAdmin()` function now checks for `request.auth.token.admin == true`.
 *   This is the standard, scalable way to manage roles in Firebase.
 */
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * @description Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the currently authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership security model.
     * @param userId The UID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description A combination check for update/delete operations to ensure the user is the
     * owner AND the document they are trying to modify actually exists.
     * @param userId The UID of the document owner.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the signed-in user has an admin custom claim.
     * This is the recommended way to handle roles.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    /**
     * @description Manages public announcements. This data is safe for anyone to read.
     *   Writes are restricted to administrators.
     * @path /announcements/{announcementId}
     */
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description Manages public port information. This data is safe for anyone to read,
     *   allowing the app to display available ports to all users. Writes are
     *   restricted to administrators to prevent tampering.
     * @path /ports/{portId}
     * @principle Implements a "Public Read with Admin-Only Writes" pattern.
     */
    match /ports/{portId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Secures passenger profiles. Each passenger can create their own profile
     *   and has full control over it. Admins can also view profiles.
     * @path /passengers/{passengerId}
     * @principle Restricts access to a user's own data tree (Self-Creation & Ownership).
     */
    match /passengers/{passengerId} {
      allow get: if isOwner(passengerId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(passengerId) && request.resource.data.id == passengerId;
      allow update: if (isExistingOwner(passengerId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isExistingOwner(passengerId) || isAdmin();
    }

    /**
     * @description Secures ship information. This is considered sensitive operational data.
     *   Only authorized administrators can read or modify this data.
     * @path /ships/{shipId}
     * @principle Enforces strict Role-Based Access Control (RBAC) for sensitive data.
     */
    match /ships/{shipId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    /**
     * @description Secures staff information. This is operational data that should
     * only be accessible to administrators.
     * @path /staff/{staffId}
     */
    match /staff/{staffId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    /**
     * @description Manages public route information. This data is safe for anyone to read.
     *   Writes are restricted to administrators to prevent tampering.
     * @path /routes/{routeId}
     * @principle Implements a "Public Read with Admin-Only Writes" pattern.
     */
    match /routes/{routeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Manages fare information. This data is safe for anyone to read.
     *   Writes are restricted to administrators.
     * @path /fares/{fareId}
     */
    match /fares/{fareId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Manages public schedule information. Like routes, schedules are readable by
     *   everyone. Modifications are restricted to administrators.
     * @path /schedules/{scheduleId}
     * @principle Implements a "Public Read with Admin-Only Writes" pattern.
     */
    match /schedules/{scheduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Secures individual booking records. A passenger can only access their
     *   own bookings. Admins can view all bookings.
     * @path /bookings/{bookingId}
     * @principle Enforces document ownership for writes and reads via a denormalized field.
     */
    match /bookings/{bookingId} {
      allow get: if isOwner(resource.data.passengerId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.passengerId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.passengerId) && request.resource.data.passengerId == resource.data.passengerId) || isAdmin();
      allow delete: if isExistingOwner(resource.data.passengerId) || isAdmin();
    }

    /**
     * @description Secures ship maintenance records. This is sensitive operational data
     *   that should only be accessible to authorized administrators.
     * @path /maintenanceRecords/{maintenanceRecordId}
     * @principle Enforces strict Role-Based Access Control (RBAC) for sensitive data.
     */
    match /maintenanceRecords/{maintenanceRecordId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    /**
     * @description Secures passenger boarding records. This is operational data that should
     * only be accessible to authorized administrators.
     * @path /boarding/{boardingId}
     */
    match /boarding/{boardingId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
    }
  }
}
