
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Global administrative override for the system owners
    function isPlatformAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rielmagpantay@gmail.com' || 
        request.auth.token.email == 'mariel.dumaoal@gmail.com'
      );
    }

    // System-wide administrative access - Priority 1
    match /{document=**} {
      allow read, write: if isPlatformAdmin();
    }

    // Check if the user is a registered staff member
    function isAdmin() {
      return isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/staff/$(request.auth.uid)));
    }
    
    function getStaffData() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isPlatformAdmin() || (isAdmin() && getStaffData().roles.hasAny([role]));
    }
    
    // Check for specific management roles
    function isSuperAdmin() {
      return isPlatformAdmin() || (isAdmin() && getStaffData().roles.hasAny(['Super Admin', 'Operations Manager']));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // System configuration is readable by all, but only editable by super admins
    match /config/settings {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /passengers/{passengerId} {
      allow get: if isOwner(passengerId) || isAdmin();
      allow list: if isAdmin();
      allow create: if true;
      allow update: if isOwner(passengerId) || isAdmin();
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ports/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ships/{id} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    match /routes/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /fares/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /schedules/{id} {
      allow read: if true;
      // Allow passengers to book (updates availableSeats) or spawn daily instances
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /bookings/{id} {
      allow get: if isOwner(resource.data.passengerId) || isAdmin();
      
      // LBAC: Desk Booking Agents and Station Managers only see bookings for their port
      allow list: if isSuperAdmin() || 
                   (hasRole('Desk Booking Agent') && resource.data.departurePortName == getStaffData().assignedPortName) ||
                   (hasRole('Station Manager') && resource.data.departurePortName == getStaffData().assignedPortName);
      
      allow create: if true;
      
      allow update: if isSuperAdmin() || 
                     (hasRole('Desk Booking Agent') && resource.data.departurePortName == getStaffData().assignedPortName);
                     
      allow delete: if isSuperAdmin();
    }

    match /maintenanceRecords/{id} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }
    
    match /boarding/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
