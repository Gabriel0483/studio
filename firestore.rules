
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * @description Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the currently authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership security model.
     * @param userId The UID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description A combination check for update/delete operations to ensure the user is the
     * owner AND the document they are trying to modify actually exists.
     * @param userId The UID of the document owner.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * @description Retrieves the roles of the currently authenticated user from the /staff collection.
     * Returns an empty list if the user has no staff document.
     */
    function getStaffRoles() {
      // Use exists() to avoid errors on non-existent documents.
      return exists(/databases/$(database)/documents/staff/$(request.auth.uid))
        ? get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.roles
        : [];
    }

     /**
     * @description Retrieves the full staff document for the currently authenticated user.
     * Returns an empty map if the user has no staff document.
     */
    function getStaffData() {
      return exists(/databases/$(database)/documents/staff/$(request.auth.uid))
        ? get(/databases/$(database)/documents/staff/$(request.auth.uid)).data
        : {};
    }

    /**
     * @description Checks if the signed-in user has the 'Super Admin' role or is the fallback admin.
     * The fallback email is for initial setup and should be replaced with a proper Super Admin user.
     */
    function isSuperAdmin() {
      return isSignedIn() && (
        getStaffRoles().hasAny(['Super Admin']) ||
        request.auth.token.email == 'rielmagpantay@gmail.com'
      );
    }
    
    /**
     * @description Checks if the user is a Station Manager or higher.
     */
    function isStationManager() {
        return isSignedIn() && (
            getStaffRoles().hasAny(['Super Admin', 'Station Manager']) || 
            request.auth.token.email == 'rielmagpantay@gmail.com'
        );
    }

    /**
     * @description Checks if the user is a Desk Booking Agent or higher.
     */
    function isDeskBookingAgent() {
        return isSignedIn() && (
            getStaffRoles().hasAny(['Super Admin', 'Station Manager', 'Desk Booking Agent']) ||
            request.auth.token.email == 'rielmagpantay@gmail.com'
        );
    }
    
    /**
     * @description Checks if the user has any admin-level role. Used for general dashboard access.
     */
    function isAnyAdmin() {
        return isSignedIn() && getStaffRoles().size() > 0 || request.auth.token.email == 'rielmagpantay@gmail.com';
    }

    /**
     * @description Checks if a staff member can access a booking. Super Admins have global access.
     *   Station Managers and Desk Booking Agents have access based on their assigned port.
     * @param bookingResource The resource object for the booking.
     */
    function canStaffAccessBooking(bookingResource) {
        if (isSuperAdmin()) {
            return true;
        }
        let staffData = getStaffData();
        if (staffData.roles.hasAny(['Station Manager', 'Desk Booking Agent'])) {
            if (!('assignedPortName' in staffData) || staffData.assignedPortName == null) {
                return false;
            }
            return bookingResource.data.departurePortName == staffData.assignedPortName;
        }
        return false;
    }
    
    /**
     * @description Checks if a staff member can access a schedule. Super Admins have global access.
     *  Station Managers can access schedules for their assigned port.
     * @param scheduleResource The resource object for the schedule.
     */
    function canStaffAccessSchedule(scheduleResource) {
        if (isSuperAdmin()) {
            return true;
        }
        let staffData = getStaffData();
        if (staffData.roles.has('Station Manager')) {
            if (!('assignedPortName' in staffData) || staffData.assignedPortName == null) {
                return false;
            }
            return scheduleResource.data.departurePortName == staffData.assignedPortName;
        }
        return false;
    }


    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    /**
     * @description Manages public announcements. This data is safe for anyone to read.
     *   Writes are restricted to Station Managers and Super Admins.
     * @path /announcements/{announcementId}
     */
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isStationManager();
    }
    
    /**
     * @description Manages public port information. Writes are restricted to Super Admins.
     * @path /ports/{portId}
     */
    match /ports/{portId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    /**
     * @description Secures passenger profiles. Each passenger can create/manage their own profile.
     *   Admins can also view profiles.
     * @path /passengers/{passengerId}
     */
    match /passengers/{passengerId} {
      allow get: if isOwner(passengerId) || isDeskBookingAgent();
      allow list: if isDeskBookingAgent();
      allow create: if isOwner(passengerId) && request.resource.data.id == passengerId;
      allow update: if (isExistingOwner(passengerId) && request.resource.data.id == resource.data.id) || isDeskBookingAgent();
      allow delete: if isExistingOwner(passengerId) || isDeskBookingAgent();
    }

    /**
     * @description Secures ship information. This is operational data.
     *   Only Super Admins can manage this data.
     * @path /ships/{shipId}
     */
    match /ships/{shipId} {
      allow read: if isAnyAdmin();
      allow write: if isSuperAdmin();
    }
    
    /**
     * @description Secures staff/admin user information. A user can read their own roles.
     *   Only Super Admins can create, update, or delete user role documents.
     * @path /staff/{staffId}
     */
    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    /**
     * @description Manages public route information. Writes are restricted to Super Admins.
     * @path /routes/{routeId}
     */
    match /routes/{routeId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    /**
     * @description Manages fare information. Writes are restricted to Super Admins.
     * @path /fares/{fareId}
     */
    match /fares/{fareId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    /**
     * @description Manages schedule templates. Writes are restricted based on role and location.
     *   All authenticated users can read schedules to facilitate booking.
     * @path /schedules/{scheduleId}
     */
    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create: if canStaffAccessSchedule(request.resource);
      allow update: if canStaffAccessSchedule(request.resource);
      allow delete: if canStaffAccessSchedule(resource);
    }

    /**
     * @description Secures individual booking records. A passenger can only access their
     *   own bookings. Staff access is role and location-based.
     * @path /bookings/{bookingId}
     */
    match /bookings/{bookingId} {
      allow get: if isOwner(resource.data.passengerId) || canStaffAccessBooking(resource);
      allow list: if isDeskBookingAgent();
      allow create: if (isSignedIn() && request.resource.data.passengerId == request.auth.uid) || canStaffAccessBooking(request.resource);
      allow update: if (isExistingOwner(resource.data.passengerId) && request.resource.data.passengerId == resource.data.passengerId) || canStaffAccessBooking(request.resource);
      allow delete: if isExistingOwner(resource.data.passengerId) || canStaffAccessBooking(resource);
    }

    /**
     * @description Secures ship maintenance records. Only Super Admins can manage this data.
     * @path /maintenanceRecords/{maintenanceRecordId}
     */
    match /maintenanceRecords/{maintenanceRecordId} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }
    
    /**
     * @description Secures passenger boarding records. This is operational data accessible
     *   to Station Managers and Super Admins for trip management.
     * @path /boarding/{boardingId}
     */
    match /boarding/{boardingId} {
        allow read: if isStationManager();
        allow write: if isStationManager();
    }
  }
}
