rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    
    function getStaffData() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAdmin() && getStaffData().roles.hasAny(['Super Admin', 'Operations Manager']);
    }

    match /config/settings {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSignedIn(); // Allow initial setup
      allow update, delete: if isSuperAdmin();
    }

    match /passengers/{passengerId} {
      allow get: if isOwner(passengerId) || isAdmin();
      allow list: if isAdmin();
      allow create: if true; // Public signup
      allow update: if isOwner(passengerId) || isAdmin();
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ports/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ships/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /routes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fares/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schedules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{id} {
      allow get: if isOwner(resource.data.passengerId) || isAdmin();
      allow list: if isAdmin(); 
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /maintenanceRecords/{id} {
      allow read, write: if isAdmin();
    }
    
    match /boarding/{id} {
      allow read, write: if isAdmin();
    }
  }
}