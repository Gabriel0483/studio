
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getStaffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    
    function getStaffData() {
        return getStaffDoc().data;
    }

    function getStaffRoles() {
      return exists(/databases/$(database)/documents/staff/$(request.auth.uid))
        ? getStaffData().roles
        : [];
    }
    
    function getCompanyId() {
        return exists(/databases/$(database)/documents/staff/$(request.auth.uid))
            ? getStaffData().companyId
            : null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && getStaffRoles().hasAny(['Super Admin']);
    }
    
    function isStationManager() {
        return isSignedIn() && getStaffRoles().hasAny(['Super Admin', 'Station Manager']);
    }

    function isDeskBookingAgent() {
        return isSignedIn() && getStaffRoles().hasAny(['Super Admin', 'Station Manager', 'Desk Booking Agent']);
    }
    
    function isAnyAdmin() {
        return isSignedIn() && getCompanyId() != null;
    }
    
    function canStaffAccessBooking(bookingResource, companyId) {
        if (!isAnyAdmin() || getCompanyId() != companyId) {
            return false;
        }
        if (isSuperAdmin()) {
            return true;
        }
        let staffData = getStaffData();
        if (staffData.roles.hasAny(['Station Manager', 'Desk Booking Agent'])) {
            return bookingResource.data.departurePortName == staffData.assignedPortName;
        }
        return false;
    }
    
    function canStaffAccessSchedule(scheduleResource, companyId) {
        if (!isAnyAdmin() || getCompanyId() != companyId) {
            return false;
        }
        if (isSuperAdmin()) {
            return true;
        }
        let staffData = getStaffData();
        if (staffData.roles.has('Station Manager')) {
            return scheduleResource.data.departurePortName == staffData.assignedPortName;
        }
        return false;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    // Global Collections
    
    match /companies/{companyId} {
        allow read: if isSignedIn();
        // Only a system-level admin should be able to create companies.
        // For now, we restrict writes to Super Admins of that company.
        allow write: if isSuperAdmin() && getCompanyId() == companyId;
    }

    match /staff/{staffId} {
      allow get: if isOwner(staffId) || (isSuperAdmin() && getStaffData().companyId == get(/databases/$(database)/documents/staff/$(staffId)).data.companyId);
      allow list: if isSuperAdmin();
      // Allow creation/update only if the user is a Super Admin of the same company.
      allow write: if isSuperAdmin() && request.resource.data.companyId == getCompanyId();
      allow delete: if isSuperAdmin() && getStaffData().companyId == resource.data.companyId;
    }

    match /passengers/{passengerId} {
      allow get: if isOwner(passengerId) || isDeskBookingAgent();
      allow list: if isDeskBookingAgent();
      allow create: if isOwner(passengerId) && request.resource.data.id == passengerId;
      allow update: if isOwner(passengerId) || isDeskBookingAgent();
      allow delete: if isOwner(passengerId) || isDeskBookingAgent();
    }
    
    // Tenant-Specific Subcollections
    
    match /companies/{companyId}/{document=**} {
        allow read, write: if isAnyAdmin() && getCompanyId() == companyId;
    }

    match /companies/{companyId}/announcements/{announcementId} {
      allow read: if true;
      allow write: if isStationManager() && getCompanyId() == companyId;
    }
    
    match /companies/{companyId}/ports/{portId} {
      allow read: if true;
      allow write: if isSuperAdmin() && getCompanyId() == companyId;
    }

    match /companies/{companyId}/ships/{shipId} {
      allow read: if isAnyAdmin() && getCompanyId() == companyId;
      allow write: if isSuperAdmin() && getCompanyId() == companyId;
    }

    match /companies/{companyId}/routes/{routeId} {
      allow read: if true;
      allow write: if isSuperAdmin() && getCompanyId() == companyId;
    }

    match /companies/{companyId}/fares/{fareId} {
      allow read: if true;
      allow write: if isSuperAdmin() && getCompanyId() == companyId;
    }

    match /companies/{companyId}/schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create: if canStaffAccessSchedule(request.resource, companyId);
      allow update: if canStaffAccessSchedule(request.resource, companyId);
      allow delete: if canStaffAccessSchedule(resource, companyId);
    }

    match /companies/{companyId}/bookings/{bookingId} {
      // A passenger can see their own booking, regardless of company.
      allow get: if (isOwner(resource.data.passengerId) && getCompanyId() == null) || canStaffAccessBooking(resource, companyId);
      allow list: if isDeskBookingAgent() && getCompanyId() == companyId;
      // A passenger can create their own booking, or an agent can.
      allow create: if (isOwner(request.resource.data.passengerId) && getCompanyId() == null) || canStaffAccessBooking(request.resource, companyId);
      allow update: if (isOwner(resource.data.passengerId) && getCompanyId() == null) || canStaffAccessBooking(request.resource, companyId);
      allow delete: if (isOwner(resource.data.passengerId) && getCompanyId() == null) || canStaffAccessBooking(resource, companyId);
    }

    match /companies/{companyId}/maintenanceRecords/{maintenanceRecordId} {
      allow read: if isSuperAdmin() && getCompanyId() == companyId;
      allow write: if isSuperAdmin() && getCompanyId() == companyId;
    }
    
    match /companies/{companyId}/boarding/{boardingId} {
        allow read: if isStationManager() && getCompanyId() == companyId;
        allow write: if isStationManager() && getCompanyId() == companyId;
    }
  }
}

    