
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getStaffData() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }

    function isPlatformAdmin() {
      return isSignedIn() && request.auth.token.email == 'rielmagpantay@gmail.com';
    }

    function isAnyAdmin() {
      return isSignedIn() && (isPlatformAdmin() || exists(/databases/$(database)/documents/staff/$(request.auth.uid)));
    }
    
    function isSuperAdmin() {
      return isPlatformAdmin() || (isAnyAdmin() && getStaffData().roles.hasAny(['Super Admin']));
    }

    // Helper to verify data belongs to the staff's tenant
    function isTenantData(resourceData) {
      return isPlatformAdmin() || (isAnyAdmin() && (getStaffData().tenantId == resourceData.tenantId));
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isSignedIn(); // Allow new operators to create their tenant profile
      allow update, delete: if isPlatformAdmin();
    }

    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isAnyAdmin();
      allow list: if isSuperAdmin();
      // Allow new operators to create their own staff record, or Platform Admin to manage all, or Super Admin to manage tenant staff
      allow create: if isSignedIn() && (request.auth.uid == staffId || isPlatformAdmin() || (isSuperAdmin() && getStaffData().tenantId == request.resource.data.tenantId));
      allow update: if isPlatformAdmin() || (isSuperAdmin() && getStaffData().tenantId == request.resource.data.tenantId);
      allow delete: if isPlatformAdmin() || (isSuperAdmin() && getStaffData().tenantId == resource.data.tenantId);
    }

    match /passengers/{passengerId} {
      allow get: if isOwner(passengerId) || isAnyAdmin();
      allow list: if isAnyAdmin();
      allow create: if isOwner(passengerId) || isAnyAdmin();
      allow update: if isOwner(passengerId) || isAnyAdmin();
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if isTenantData(request.resource.data) || (resource != null && isTenantData(resource.data));
    }
    
    match /ports/{id} {
      allow read: if true;
      allow write: if isTenantData(request.resource.data) || (resource != null && isTenantData(resource.data));
    }

    match /ships/{id} {
      allow read: if isTenantData(resource.data);
      allow write: if isTenantData(request.resource.data) || (resource != null && isTenantData(resource.data));
    }

    match /routes/{id} {
      allow read: if true;
      allow write: if isTenantData(request.resource.data) || (resource != null && isTenantData(resource.data));
    }

    match /fares/{id} {
      allow read: if true;
      allow write: if isTenantData(request.resource.data) || (resource != null && isTenantData(resource.data));
    }

    match /schedules/{id} {
      allow read: if true; // Public status page
      allow write: if isTenantData(request.resource.data) || (resource != null && isTenantData(resource.data));
    }

    match /bookings/{id} {
      allow get: if isOwner(resource.data.passengerId) || isTenantData(resource.data);
      allow list: if isAnyAdmin(); 
      allow create: if isSignedIn();
      allow update: if isTenantData(resource.data);
      allow delete: if isTenantData(resource.data);
    }

    match /maintenanceRecords/{id} {
      allow read, write: if isTenantData(resource.data) || isTenantData(request.resource.data);
    }
    
    match /boarding/{id} {
      allow read, write: if isAnyAdmin();
    }
  }
}
