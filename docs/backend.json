
{
  "entities": {
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents an operator or company using the platform.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the tenant." },
        "name": { "type": "string", "description": "The name of the operator." },
        "subdomain": { "type": "string", "description": "Reserved for future vanity URL use." },
        "logoUrl": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "Announcement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Announcement",
      "type": "object",
      "description": "Represents a public advisory or announcement.",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string", "description": "The ID of the tenant this announcement belongs to." },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["General Information", "Weather Update", "Route Change", "Fare Change", "Service Disruption"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "title", "content", "category", "createdAt"]
    },
    "Port": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Port",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["id", "tenantId", "name", "location"]
    },
    "Passenger": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Passenger",
      "type": "object",
      "description": "Global passenger profile (shared across tenants).",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "familyMembers": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "fullName": { "type": "string" } } } }
      },
      "required": ["id", "firstName", "lastName", "email"]
    },
    "Ship": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Ship",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "capacity": { "type": "number" },
        "status": { "type": "string" },
        "vesselType": { "type": "string" }
      },
      "required": ["id", "tenantId", "name", "capacity", "status", "vesselType"]
    },
    "AdminUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminUser",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "tenantId": { "type": "string", "description": "The operator this staff member works for." },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "tenantId", "email", "name", "roles"]
    },
    "Route": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Route",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "departure": { "type": "string" },
        "destination": { "type": "string" }
      },
      "required": ["id", "tenantId", "name", "departure", "destination"]
    },
    "Fare": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Fare",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "routeId": { "type": "string" },
        "price": { "type": "number" },
        "passengerType": { "type": "string" }
      },
      "required": ["id", "tenantId", "routeId", "price", "passengerType"]
    },
    "Schedule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Schedule",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "tripType": { "type": "string", "enum": ["Daily", "Special"] },
        "shipId": { "type": "string" },
        "routeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "departureTime": { "type": "string", "format": "time" },
        "availableSeats": { "type": "number" }
      },
      "required": ["id", "tenantId", "tripType", "routeId", "departureTime", "availableSeats"]
    },
    "Booking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "passengerId": { "type": "string" },
        "scheduleId": { "type": "string" },
        "travelDate": { "type": "string", "format": "date" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "tenantId", "passengerId", "scheduleId", "travelDate", "totalPrice", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/tenants/{tenantId}", "definition": { "entityName": "Tenant", "schema": { "$ref": "#/backend/entities/Tenant" }, "description": "Operator profile." } },
      { "path": "/staff/{staffId}", "definition": { "entityName": "AdminUser", "schema": { "$ref": "#/backend/entities/AdminUser" }, "description": "Staff account with tenantId." } },
      { "path": "/passengers/{passengerId}", "definition": { "entityName": "Passenger", "schema": { "$ref": "#/backend/entities/Passenger" }, "description": "Global passenger profile." } },
      { "path": "/announcements/{id}", "definition": { "entityName": "Announcement", "schema": { "$ref": "#/backend/entities/Announcement" }, "description": "Tenant specific announcements." } },
      { "path": "/ports/{id}", "definition": { "entityName": "Port", "schema": { "$ref": "#/backend/entities/Port" } } },
      { "path": "/ships/{id}", "definition": { "entityName": "Ship", "schema": { "$ref": "#/backend/entities/Ship" } } },
      { "path": "/routes/{id}", "definition": { "entityName": "Route", "schema": { "$ref": "#/backend/entities/Route" } } },
      { "path": "/fares/{id}", "definition": { "entityName": "Fare", "schema": { "$ref": "#/backend/entities/Fare" } } },
      { "path": "/schedules/{id}", "definition": { "entityName": "Schedule", "schema": { "$ref": "#/backend/entities/Schedule" } } },
      { "path": "/bookings/{id}", "definition": { "entityName": "Booking", "schema": { "$ref": "#/backend/entities/Booking" } } }
    ]
  }
}
