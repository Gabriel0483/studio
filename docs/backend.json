
{
  "entities": {
    "Announcement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Announcement",
      "type": "object",
      "description": "Represents a public advisory or announcement.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["General Information", "Weather Update", "Route Change", "Fare Change", "Service Disruption"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "category", "createdAt"]
    },
    "Port": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Port",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["id", "name", "location"]
    },
    "Passenger": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Passenger",
      "type": "object",
      "description": "Passenger profile.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "familyMembers": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "fullName": { "type": "string" } } } }
      },
      "required": ["id", "firstName", "lastName", "email"]
    },
    "Ship": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Ship",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "capacity": { "type": "number" },
        "status": { "type": "string" },
        "vesselType": { "type": "string" }
      },
      "required": ["id", "name", "capacity", "status", "vesselType"]
    },
    "AdminUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminUser",
      "type": "object",
      "description": "Staff member with dashboard access.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "assignedPortId": { "type": "string" },
        "assignedPortName": { "type": "string" },
        "assignedShipId": { "type": "string" },
        "assignedShipName": { "type": "string" }
      },
      "required": ["uid", "email", "name", "roles"]
    },
    "Route": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Route",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "departure": { "type": "string" },
        "destination": { "type": "string" }
      },
      "required": ["id", "name", "departure", "destination"]
    },
    "Fare": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Fare",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "routeId": { "type": "string" },
        "price": { "type": "number" },
        "passengerType": { "type": "string" }
      },
      "required": ["id", "routeId", "price", "passengerType"]
    },
    "Schedule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Schedule",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tripType": { "type": "string", "enum": ["Daily", "Special"] },
        "shipId": { "type": "string" },
        "routeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "departureTime": { "type": "string", "format": "time" },
        "availableSeats": { "type": "number" }
      },
      "required": ["id", "tripType", "routeId", "departureTime", "availableSeats"]
    },
    "Booking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "passengerId": { "type": "string" },
        "scheduleId": { "type": "string" },
        "travelDate": { "type": "string", "format": "date" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string" },
        "departurePortName": { "type": "string" }
      },
      "required": ["id", "passengerId", "scheduleId", "travelDate", "totalPrice", "status"]
    },
    "SystemConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SystemConfig",
      "type": "object",
      "description": "Global settings for the application.",
      "properties": {
        "companyName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroImageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/config/settings", "definition": { "entityName": "SystemConfig", "schema": { "$ref": "#/backend/entities/SystemConfig" } } },
      { "path": "/staff/{staffId}", "definition": { "entityName": "AdminUser", "schema": { "$ref": "#/backend/entities/AdminUser" } } },
      { "path": "/passengers/{passengerId}", "definition": { "entityName": "Passenger", "schema": { "$ref": "#/backend/entities/Passenger" } } },
      { "path": "/announcements/{id}", "definition": { "entityName": "Announcement", "schema": { "$ref": "#/backend/entities/Announcement" } } },
      { "path": "/ports/{id}", "definition": { "entityName": "Port", "schema": { "$ref": "#/backend/entities/Port" } } },
      { "path": "/ships/{id}", "definition": { "entityName": "Ship", "schema": { "$ref": "#/backend/entities/Ship" } } },
      { "path": "/routes/{id}", "definition": { "entityName": "Route", "schema": { "$ref": "#/backend/entities/Route" } } },
      { "path": "/fares/{id}", "definition": { "entityName": "Fare", "schema": { "$ref": "#/backend/entities/Fare" } } },
      { "path": "/schedules/{id}", "definition": { "entityName": "Schedule", "schema": { "$ref": "#/backend/entities/Schedule" } } },
      { "path": "/bookings/{id}", "definition": { "entityName": "Booking", "schema": { "$ref": "#/backend/entities/Booking" } } }
    ]
  }
}
